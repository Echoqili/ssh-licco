{
  "default_client": "asyncssh",
  "clients": {
    "paramiko": {
      "enabled": true,
      "name": "Paramiko",
      "description": "纯 Python 实现，功能完善，稳定可靠",
      "timeout": 30,
      "keepalive_interval": 30,
      "session_timeout": 7200
    },
    "fabric": {
      "enabled": false,
      "name": "Fabric",
      "description": "基于 Paramiko 的高级 API，更易用",
      "timeout": 30,
      "keepalive_interval": 30,
      "session_timeout": 7200
    },
    "asyncssh": {
      "enabled": true,
      "name": "AsyncSSH",
      "description": "异步实现，高性能",
      "timeout": 30,
      "keepalive_interval": 30,
      "session_timeout": 7200
    },
    "ssh2": {
      "enabled": false,
      "name": "SSH2 (libssh2)",
      "description": "C 扩展，极致性能",
      "timeout": 30,
      "keepalive_interval": 30,
      "session_timeout": 7200
    },
    "system": {
      "enabled": false,
      "name": "System SSH",
      "description": "调用系统 SSH 命令，最稳定",
      "timeout": 30,
      "keepalive_interval": 30,
      "session_timeout": 7200
    }
  }
}
