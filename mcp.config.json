{
  "mcpServers": {
    "GitHub": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
      },
      "fromGalleryId": "modelcontextprotocol.servers_github"
    },
    "Gitee": {
      "command": "mcp-gitee",
      "args": [
        "--transport",
        "sse",
        "--sse-address",
        "0.0.0.0:8000"
      ],
      "env": {
        "GITEE_ACCESS_TOKEN": "${GITEE_TOKEN}",
        "GITEE_API_BASE": "https://gitee.com/api/v5"
      },
      "fromGalleryId": "oschina.mcp-gitee"
    },
    "ssh": {
      "command": "ssh-licco",
      "env": {
        "SSH_HOST": "${SSH_HOST}",
        "SSH_USER": "${SSH_USER}",
        "SSH_PASSWORD": "${SSH_PASSWORD}",
        "SSH_PORT": "22",
        "SSH_TIMEOUT": "120",
        "SSH_KEEPALIVE_INTERVAL": "30",
        "SSH_SESSION_TIMEOUT": "7200",
        "SSH_CLIENT_TYPE": "${SSH_CLIENT_TYPE}"
      }
    }
  }
}